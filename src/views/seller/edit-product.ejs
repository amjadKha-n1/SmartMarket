<link rel="stylesheet" href="/css/form.css">
<div class="div-container">
    <h1>Edit product</h1>
    <form action="/seller/<%= product._id %>/edit-product" method="POST" enctype="multipart/form-data">
        <p>
            <label for="title">Title</label>
            <input type="text" id="title" name="title" value="<%= product.title %>" minlength="3" required>
        </p>
        <p>
            <label for="description">Description</label>
            <input type="text" id="description" name="description" value="<%= product.description %>" required>
        </p>
        <p>
            <label for="category">Category</label>
            <select name="categoryId" id="category" required>
              <% for (const category of categories) { %>
                  <option value="<%= category._id %>"><%= category.name %></option>
              <% } %>
            </select>
            
        </p>
        <p>
            <label for="price">Price</label>
            <input type="number" id="price" name="price" value="<%= product.price %>" required>
        </p>
        <p>
            <label for="stock">Stock Quantity</label>
            <input type="number" id="stock" name="stock" value="<%= product.stock %>" required>
        </p>
        <p class="image">
            <input type="file" name="productImage" id="image">
        </p>
        <button>Submit</button>
    </form>
</div>