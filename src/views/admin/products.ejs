<link rel="stylesheet" href="/css/dashboard.css">
<h2 class="titles">All products</h2>
<table class="table table-bordered">
    <thead>
        <th>Product Image</th>
        <th>Product Name</th>
        <th>Seller</th>
        <th>Price</th>
        <th>Approvel</th>
        <th>Action</th>
    </thead>
    <tbody>
        <% for (const product of products) { %>
            <tr class="product-row">    
                <div>
                    <td class="td-img"><img class="img" src="<%= product.images[0] %>" alt="Product Image"></td>
                </div>
                <td><%= product.title %></td>
                <td><%= product.sellerId.userId.name %></td>
                <td><%= product.price %></td>
                <td><%= product.isApproved %></td>
                <td class="btn-td">
                  <div class="btn-div">
                    <form action="/admin/<%= product._id %>/approveProduct" method="POST">
                      <input type="hidden" name="redirect" value="<%= currentPage = '/admin/products' %>">
                      <button class="btn-1">Approve</button>
                    </form>
                    <form action="/admin/<%= product._id %>/rejectProduct" method="POST">
                      <button class="btn-2">reject</button>
                    </form>
                  </div>
                </td>
            </tr>
        <% } %>
    </tbody>
</table>